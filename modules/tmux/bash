settitle() {
  printf "\033k%s\033\\" "$1"
}

# Extract a display name from ssh/mosh arguments for the tmux window title.
# Strips flags, drops the user@ if it matches $USER, and removes the last
# domain component (e.g. host.example.com -> host.example).
parse_host() {
  local display=""
  shift  # drop the command name (ssh/mosh)
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -p|-i|-o|-l|-J|-F|-L|-R|-D|-W|-b|-c|-e|-m|-Q|-S) shift 2 ;; # flag with a value — skip both
      -*)  shift ;; # skip other flags
      *)   display="$1"; break ;; # first non-flag is the destination
    esac
  done

  [[ -z "$display" ]] && return

  # strip user@ if it matches current user
  display="${display/#${USER}@/}"

  # drop last domain component (host.example.com -> host.example, example.com -> example)
  if [[ "$display" == *.* ]]; then
    display="${display%.*}"
  fi

  printf '%s' "$display"
}

# Wrap remote shell commands to set the tmux window title to the hostname
remote_shell_wrapper() {
  local title
  title="$(parse_host "$@")"

  [[ -n "$title" ]] && settitle "$title"

  # Re-enable automatic-rename when the session ends, even if killed or crashed
  (
    [[ -n "$title" && -n "$TMUX" ]] && trap 'tmux set-window-option automatic-rename on' EXIT
    command "$@"
  )
}

ssh() {
  remote_shell_wrapper ssh "$@"
}

mosh() {
  remote_shell_wrapper mosh "$@"
}

# Set a stable SSH agent socket path. On SSH login the real $SSH_AUTH_SOCK is a
# different path per connection. This will point to a stable symlink so
# long-lived shells inside tmux keep working across reconnects.
if [ -S "${SSH_AUTH_SOCK:-}" ] && [ "$SSH_AUTH_SOCK" != "$HOME/.ssh/auth_sock" ]; then
  ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/auth_sock"
fi
[ -e "$HOME/.ssh/auth_sock" ] && export SSH_AUTH_SOCK="$HOME/.ssh/auth_sock"
